# Netlify API (server-side — /api/tributes). Copy to .env.local and fill in.
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=
# Optional — skip form lookup if set (from GET .../sites/:id/forms)
# NETLIFY_FORM_ID=

# Optional — append data/approvedTributes.ts after Netlify rows (migration)
# NETLIFY_MERGE_STATIC_SEED=true

# Tribute form proxy (server-side — /api/tribute-submit). Required for local `npm run dev`.
# Full URL to the deployed static form page Netlify processes:
# NETLIFY_TRIBUTE_POST_URL=https://your-site.netlify.app/netlify-forms.html
# On Netlify builds, URL / DEPLOY_PRIME_URL is used if this is unset.
